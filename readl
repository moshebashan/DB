# -*- coding: utf-8 -*-

"""
READL - read labels:
this script will split long recordings to short labeled segments (samples).
readl will take as input wav files and their corresponding text files containing the labels.
the segmentation will occur according to labes start and end time specified in text files.
the text files required to have the same name as the corresponding wav files.
this script is compatible with audacity softwere with or without spectral selection (min and max frequency). 
    
inputs:
    1. label table - text file contain all the labels with names for all species.
    2. files directory - contains wav files and their corresponding text files. 
    3. name for results directory.  
output:
    1. wav files - samples of all labeled segments - will be store in the results directory.
    
@author: Moshe Bashan    
"""

# import packages:
import librosa, librosa.display
import glob, os
import numpy as np
import pandas as pd
import soundfile as sf
import time

start = time.time()

# labels table file - (input 1):
labels_dir = r"D:\google drive\לימודים\תואר שני\project bird recognition\python\readl" # label table path
os.chdir(labels_dir)
label_table = pd.read_csv("label_table.txt", sep="\t", header=None, encoding=('iso8859_8')) # read species index numbers (label table)

# set working directory - set to directory that contain the wav and text files) - (input 2):
path = r"D:\google drive\לימודים\תואר שני\project bird recognition\Recordings\מאגר הקלטות זמני\הקלטות מקסנו קנטו\תנשמת\מתויג" # set to current folder
os.chdir(path) 
results_dir = 'samples' # name of the results folder - (input 3)
os.mkdir(results_dir) # make new folder for results

wav_files = glob.glob("*.wav") # make list of all wav files
text_files = glob.glob("*.txt") # make list of all text files
meta = pd.DataFrame(columns=('file', 'label', 'start time', 'end time', 'min freq', 'max freq', 'found')) # new dataframe for metadata
metarow = 0
unidentified = pd.DataFrame(columns=('file name', 'index', 'lable')) # new dataframe for unidentified labels 
unidentified_row = 0

# loop for all files:
for i in range(len(wav_files)):
    file_name = wav_files[i] # get the file name
    fname = file_name[0:len(file_name)-4] # get the file name without the suffix
    #signal, sr = librosa.load(file_name, sr=22050) # read the wav file
    text_file = pd.read_csv(fname + '.txt', sep="\t", header=None) # read the text file
    
    if text_file.shape[0]<=1 or text_file[0][1] != '\\' : # if spectral selection mode is disable or enable
        spectral_selection = 'disable'
        T0 = text_file[2]
        T1 = text_file[0]
        T2 = text_file[1]
        table = pd.concat([T0.reset_index(drop=True), T1.reset_index(drop=True), 
                           T2.reset_index(drop=True)], axis = 1)
        table.columns = [0,1,2]
    else:
        spectral_selection = 'enable'
        T0 = text_file[2][0::2].to_frame() # get all lables from the text file
        T1 = text_file[0][0::2].to_frame() # get the start time from all samples
        T2 = text_file[1][0::2].to_frame() # get the end time from all samples
        T3 = text_file[1][1::2].to_frame() # get the minimum frequency from all samples
        T4 = text_file[2][1::2].to_frame() # get the maximum frequency from all samples
        table = pd.concat([T0.reset_index(drop=True), T1.reset_index(drop=True), 
                           T2.reset_index(drop=True), T3.reset_index(drop=True), T4.reset_index(drop=True)], axis = 1)
        table.columns = [0,1,2,3,4]
       
# loop for all lables:   
    for j in range(len(table)): 
        index = j+1 # index number of sample in the recording
        lable = table[0][j] # lable name (species)
        col = 1
        match = label_table[label_table[col] == lable] # find match for lable from file with label table (in column=1)
    
        while col < np.shape(label_table)[1]-1:  # look for label match in different column if label is unidentified
            col = col + 1
            if match.shape[0] == 0:
                match = label_table[label_table[col] == lable] # find match for lable from file with label table (in column=col)
        
        if match.shape[0] == 0: # if label is unidentified
            found = 'no'
            unidentified.loc[unidentified_row] = [fname, index, lable] # update unidentified table
            unidentified_row = unidentified_row + 1
            #found = 'no'
        elif match.shape[0] != 0: # if lable was identified:
            found = 'yes'
            species_index = int(match[0]) # in file index lable
            new_file_name = str(species_index) + '_' + str(index) + '_' + file_name # new file name     
    
            samp_start = float(table[1][j]) # start time of the sample in seconds
            samp_duration = float(table[2][j]) - float(T1.iloc[j]) # duration of the sample in seconds
            # read the audio from the file:           
            sample, sr = librosa.load(wav_files[i], offset = samp_start, duration = samp_duration, sr = 44100)
            
            if sr != 44100: # resample to 44.100 kHz if otherwise 
                librosa.resample(sample, sr, 44100)
            
            # write the sample in the results folder:
            os.chdir(results_dir) # change to results folder
            sf.write(new_file_name,sample, samplerate = sr) # write the wav file - (output)
            os.chdir(path) # change back to working directory
            
# update metadata:
            if spectral_selection == "enable": # update metadata with or without spectral selection
                meta.loc[metarow] = [fname,table[0][j],table[1][j],table[2][j],table[3][j],table[4][j], found]
                metarow = metarow + 1
            else:
                meta.loc[metarow] = [fname,table[0][j],table[1][j],table[2][j],[],[], found]
                metarow = metarow + 1

# save metadata to a pickle file:
os.chdir(results_dir)
#meta.to_pickle("metadata.pkl")   
       
if unidentified.shape[0] > 0:
    print("=====  unidentified labels  =====:")
    print(unidentified)
    print("=================================")
    
end = time.time()
print('total run time : ',round((end-start)/60,2), 'minunts')
print("======  End Of Process  ======")
 
 
